{
  "manifest_version": 3,
  "name": "Ozon CRM Мега-помощник",
  "version": "10.9",
  "description": "Автообновление через chrome.storage",
  "permissions": [
    "storage",
    "clipboardWrite",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://crm.o3team.ru/*",
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://crm.o3team.ru/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "48": "icon.png"
  }
}
