{
  "manifest_version": 3,
  "name": "Ozon CRM Мега-помощник",
  "version": "10.6",
  "description": "Автоприветствие, перефразирование, ИИ-шаблоны",
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": ["https://crm.o3team.ru/*"],
  "content_scripts": [
    {
      "matches": ["https://crm.o3team.ru/*"],
      "js": ["config.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "48": "icon.png"
  }
}
